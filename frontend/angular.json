{
  "$schema": "https://angular.io/config/angular.json",
  "version": 1,
  "projects": {
    "edf-frontend": {
      "projectType": "application",
      "root": "src",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/edf-frontend",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.json",
            "assets": ["src/assets"],
            "styles": ["src/styles.css"]
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "edf-frontend:build"
          }
        }
      }
    }
  },
  "defaultProject": "edf-frontend",
  "cli": {
    "analytics": false
  }
}
