# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

############################################
# ANGULAR / NODE (frontend)
############################################

# Node modules
frontend/node_modules/
node_modules/

# Angular build output
frontend/dist/
dist/

# Angular cache
frontend/.angular/
.angular/

# Environment files (optional if you don't want them in repo)
frontend/src/environments/*.local.ts

# Package lock (optional — usually KEEP this)
# package-lock.json

############################################
